<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Card Styles                                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="DashboardCardStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Status Badge Styles                                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="StatusActiveBrush" Color="#22C55E" />
    <SolidColorBrush x:Key="StatusDisabledBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="StatusWarningBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#3B82F6" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Empty State Style                                          -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="EmptyStateIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="48" />
        <Setter Property="Opacity" Value="0.3" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EmptyStateTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EmptyStateSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Opacity" Value="0.35" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Page Header Style                                          -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="PageHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Accent Icon Circle (for dashboard card headers)            -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="CardIconCircleStyle" TargetType="Border">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Background" Value="{ThemeResource SystemAccentColor}" />
        <Setter Property="Opacity" Value="0.15" />
    </Style>

</ResourceDictionary>
