<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OmnifinNative.Views.SystemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmnifinNative.Views"
    xmlns:models="using:OmnifinNative.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <FontIcon Glyph="&#xE912;" FontSize="24" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
            <TextBlock Text="System Administration" Style="{StaticResource PageHeaderStyle}" />
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0" Visibility="Collapsed" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Tasks and Power Control Column -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Background Tasks Panel -->
                <StackPanel Grid.Row="0" Spacing="12">
                    <TextBlock Text="Trigger Background Tasks" FontWeight="SemiBold" FontSize="14" />
                    <ListView
                        x:Name="TasksListView"
                        Height="220"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        ItemsSource="{x:Bind Tasks}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:TaskInfo">
                                <StackPanel Padding="8,6" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE815;" FontSize="14" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Description}" FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button x:Name="RunTaskButton" Style="{StaticResource AccentButtonStyle}" Click="RunTaskButton_Click" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE768;" FontSize="14" />
                            <TextBlock Text="Run Selected Task" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Power Controls Panel -->
                <StackPanel Grid.Row="1" Spacing="12" Margin="0,24,0,0">
                    <TextBlock Text="Server Power Control" FontWeight="SemiBold" FontSize="14" />
                    <Border Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Restarting the server will disconnect active logins. Make sure no backup tasks are currently running." FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
                            <Button x:Name="RestartButton" Style="{StaticResource AccentButtonStyle}" Click="RestartButton_Click" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                    <TextBlock Text="Restart Server" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Logs Viewer Column -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <!-- Logs Header -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Server Logs (Last 100 lines)" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                    <Button Click="RefreshLogsButton_Click" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="12" />
                            <TextBlock Text="Refresh Logs" />
                        </StackPanel>
                    </Button>
                </Grid>
                
                <!-- Logs Textbox Container Card -->
                <Border Grid.Row="1" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <TextBox
                        x:Name="LogsTextBox"
                        FontFamily="Consolas"
                        FontSize="11"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        TextWrapping="NoWrap"
                        Background="Transparent"
                        BorderThickness="0"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        Padding="12" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
