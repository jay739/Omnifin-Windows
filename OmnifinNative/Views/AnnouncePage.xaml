<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OmnifinNative.Views.AnnouncePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmnifinNative.Views"
    xmlns:models="using:OmnifinNative.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <FontIcon Glyph="&#xE789;" FontSize="24" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
            <TextBlock Text="Announcements" Style="{StaticResource PageHeaderStyle}" />
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0" Visibility="Collapsed" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Recipients Selection list panel -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
                    <TextBlock Text="Recipients" FontWeight="SemiBold" FontSize="14" />
                    <CheckBox x:Name="SelectAllCheckBox" Content="Select All Users" Click="SelectAllCheckBox_Click" />
                </StackPanel>
                
                <ListView
                    x:Name="UsersListView"
                    Grid.Row="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ItemsSource="{x:Bind Users}"
                    SelectionMode="Multiple"
                    SelectionChanged="UsersListView_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:RespUser">
                            <Grid Padding="4,2" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE77B;" FontSize="14" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" FontSize="13" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Announcement Composer panel -->
            <StackPanel Grid.Column="1" Spacing="16">
                <TextBlock Text="Compose Announcement" FontWeight="SemiBold" FontSize="14" />

                <TextBox x:Name="SubjectBox" Header="Subject" PlaceholderText="e.g. Omnifin Server Updates" HorizontalAlignment="Stretch">
                    <TextBox.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                <FontIcon Glyph="&#xE7C1;" FontSize="13" VerticalAlignment="Center" />
                                <TextBlock Text="Subject" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </TextBox.HeaderTemplate>
                </TextBox>

                <TextBox
                    x:Name="MessageBox"
                    Header="Message"
                    PlaceholderText="Markdown formatting is supported. Use this space to write details about the updates, password change policies, or server maintenance..."
                    AcceptsReturn="True"
                    Height="240"
                    TextWrapping="Wrap"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    HorizontalAlignment="Stretch">
                    <TextBox.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                <FontIcon Glyph="&#xE70F;" FontSize="13" VerticalAlignment="Center" />
                                <TextBlock Text="Message Content" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </TextBox.HeaderTemplate>
                </TextBox>

                <Border Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <CheckBox x:Name="TestCheckBox" Content="Send as test to myself only" IsChecked="True" />
                        <TextBlock Text="Note: Test announcements are sent to the logged-in administrator's email. Non-test announcements are dispatched to all selected recipients." FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Button
                    x:Name="SendButton"
                    Style="{StaticResource AccentButtonStyle}"
                    Width="200"
                    Click="SendButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE724;" FontSize="16" />
                        <TextBlock Text="Send Announcement" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
