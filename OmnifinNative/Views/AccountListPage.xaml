<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OmnifinNative.AccountListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmnifinNative"
    xmlns:models="using:OmnifinNative.Models"
    xmlns:converters="using:OmnifinNative.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToStatusConverter x:Key="BoolToStatusConverter" />
        <converters:SecondsToDurationConverter x:Key="SecondsToDurationConverter" />
    </Page.Resources>

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="Accounts" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Content="Refresh" Click="RefreshButton_Click" />
            <Button Content="Enable" Click="EnableButton_Click" />
            <Button Content="Disable" Click="DisableButton_Click" />
            <Button Content="Extend 30 days" Click="ExtendButton_Click" />
            <Button Content="Delete" Click="DeleteButton_Click" Style="{StaticResource AccentButtonStyle}" />
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
        </StackPanel>

        <ListView
            x:Name="UsersListView"
            Grid.Row="1"
            ItemsSource="{x:Bind Users}"
            SelectionMode="Multiple">
            <ListView.HeaderTemplate>
                <DataTemplate>
                    <Grid Padding="12,6" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="Email" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="Watch time" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="Status" FontWeight="SemiBold" />
                    </Grid>
                </DataTemplate>
            </ListView.HeaderTemplate>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:RespUser">
                    <Grid Padding="12,6" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Name}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Email}" VerticalAlignment="Center" Opacity="0.7" />
                        <TextBlock
                            Grid.Column="2"
                            Text="{x:Bind WatchTimeSeconds, Converter={StaticResource SecondsToDurationConverter}}"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Grid.Column="3"
                            Text="{x:Bind Disabled, Converter={StaticResource BoolToStatusConverter}}"
                            VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
