<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OmnifinNative.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmnifinNative"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Centered Login Card -->
        <Border
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadius="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            Padding="40,36"
            Width="400">

            <StackPanel Spacing="16">

                <!-- App Icon -->
                <Image
                    Source="Assets/AppIcon.ico"
                    Width="64"
                    Height="64"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,4" />

                <!-- Title -->
                <TextBlock
                    Text="Omnifin"
                    FontSize="28"
                    FontWeight="Bold"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="Sign in to manage your media server"
                    Opacity="0.6"
                    FontSize="13"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8" />

                <!-- Form Fields -->
                <TextBox
                    x:Name="ServerUrlBox"
                    Header="Server URL"
                    PlaceholderText="https://your-server.example.com">
                    <TextBox.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE774;" FontSize="14" />
                                <TextBlock Text="Server URL" />
                            </StackPanel>
                        </DataTemplate>
                    </TextBox.HeaderTemplate>
                </TextBox>

                <TextBox
                    x:Name="UsernameBox"
                    Header="Username">
                    <TextBox.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE77B;" FontSize="14" />
                                <TextBlock Text="Username" />
                            </StackPanel>
                        </DataTemplate>
                    </TextBox.HeaderTemplate>
                </TextBox>

                <PasswordBox
                    x:Name="PasswordBox"
                    Header="Password"
                    KeyDown="PasswordBox_KeyDown">
                    <PasswordBox.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8D7;" FontSize="14" />
                                <TextBlock Text="Password" />
                            </StackPanel>
                        </DataTemplate>
                    </PasswordBox.HeaderTemplate>
                </PasswordBox>

                <CheckBox
                    x:Name="AdminLoginCheckBox"
                    Content="Login as Administrator"
                    IsChecked="True"
                    Margin="0,4,0,0" />

                <!-- Error Text -->
                <TextBlock
                    x:Name="ErrorText"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    TextWrapping="Wrap"
                    Visibility="Collapsed" />

                <!-- Sign In Button -->
                <Button
                    x:Name="LoginButton"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="LoginButton_Click"
                    Margin="0,8,0,0"
                    Padding="0,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8D7;" FontSize="16" />
                        <TextBlock Text="Sign In" />
                    </StackPanel>
                </Button>

                <ProgressRing
                    x:Name="LoginProgress"
                    IsActive="False"
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
