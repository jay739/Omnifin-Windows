<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OmnifinNative.Views.ConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmnifinNative.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="Server Configuration" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
            <TextBlock x:Name="StatusText" Foreground="Green" VerticalAlignment="Center" Margin="8,0,0,0" Visibility="Collapsed" />
        </StackPanel>

        <Pivot x:Name="ConfigPivot" Grid.Row="1" Margin="0,0,0,16" />

        <!-- Save Button Panel -->
        <CommandBar Grid.Row="2" DefaultLabelPosition="Right" HorizontalAlignment="Left" Background="Transparent" IsOpen="False">
            <AppBarButton Icon="Save" Label="Save Configuration" Click="SaveButton_Click" />
        </CommandBar>
    </Grid>
</Page>
